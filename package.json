{
  "name": "notion-jira-techdebt-worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.worker.json",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "vpn:check": "bash scripts/check-vpn-reactivation-needed.sh",
    "sync:local": "bash -c 'set -a; source .env; set +a; npx tsx scripts/sync-techdebt-stories.ts'",
    "sync:worker": "ntn workers sync trigger techdebtStoriesSync --local"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.9.2"
  },
  "dependencies": {
    "@notionhq/workers": ">=0.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.0"
  }
}
